# ─────────────────────────────────────────────
#  Secrets & credentials — NEVER commit these
# ─────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
serviceAccountKey.json
firebase-adminsdk*.json
google-services.json
GoogleService-Info.plist
*firebase*.json
*.pem
*.key

# ─────────────────────────────────────────────
#  Python (backend + ml_service)
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
.installed.cfg

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────
#  ML model artifacts & vector store
#  (large / regenerated — track via Git LFS if
#   you truly need them versioned)
# ─────────────────────────────────────────────
*.pkl
aoun_model.pkl
aoun_scaler.pkl
aoun_imputer.pkl
aoun_label_encoder.pkl

# ChromaDB persisted vector store
chroma/
chroma_db/
.chroma/
chromadb/
*.sqlite3
*.duckdb

# ─────────────────────────────────────────────
#  Dataset (not redistributable — see README)
# ─────────────────────────────────────────────
cancer_patient_data_sets.csv
data/
*.csv
!requirements*.csv          # keep any config CSVs you actually need
knowledge_pdfs/*.pdf        # ingested clinical PDFs (redistribution restricted)

# ─────────────────────────────────────────────
#  Flutter / Dart (aoun_app)
# ─────────────────────────────────────────────
aoun_app/.dart_tool/
aoun_app/.flutter-plugins
aoun_app/.flutter-plugins-dependencies
aoun_app/.packages
aoun_app/.pub-cache/
aoun_app/.pub/
aoun_app/build/
aoun_app/**/doc/api/
aoun_app/.fvm/
*.dart.js
*.info.json
*.js.map
.flutter-plugins
.flutter-plugins-dependencies

# Flutter — Android
aoun_app/android/.gradle/
aoun_app/android/captures/
aoun_app/android/local.properties
aoun_app/android/**/GeneratedPluginRegistrant.java
aoun_app/android/key.properties
aoun_app/android/app/google-services.json
**/*.keystore
**/*.jks

# Flutter — iOS
aoun_app/ios/Pods/
aoun_app/ios/.symlinks/
aoun_app/ios/Flutter/Flutter.framework
aoun_app/ios/Flutter/Flutter.podspec
aoun_app/ios/Runner/GoogleService-Info.plist
**/Podfile.lock

